{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node"],
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": [
		"index.ts",
		"core/**/*.ts",
		"adapter/**/*.ts",
		"pi-coding-agent.d.ts",
		"**/*.test.ts",
		"vitest.config.ts"
	]
}
